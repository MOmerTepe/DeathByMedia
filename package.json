{
  "name": "dbc-media",
  "version": "1.1.3",
  "description": "Media Converter & YouTube Downloader",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "bundle:bin": "node scripts/copy-binaries.js",
    "start": "npm run build:renderer && electron .",
    "build": "npm run bundle:bin && npm run build:renderer && electron-builder --win",
    "build:portable": "npm run bundle:bin && npm run build:renderer && electron-builder --win portable"
  },
  "author": "Death By Media",
  "license": "MIT",
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.0.1",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "svelte": "^4.2.8",
    "vite": "^5.0.10"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0"
  },
  "build": {
    "appId": "com.dbcmedia.app",
    "productName": "Death By Media",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "build/**/*",
      "node_modules/**/*",
      "package.json",
      "!node_modules/ffmpeg-static/ffmpeg.exe",
      "!node_modules/ffprobe-static/bin/**"
    ],
    "extraResources": [
      {
        "from": "bin/",
        "to": "bin/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "artifactName": "DeathByMedia-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "DeathByMedia-Portable-${version}.${ext}"
    }
  }
}